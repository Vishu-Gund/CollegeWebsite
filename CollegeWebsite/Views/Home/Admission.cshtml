@{
    ViewData["Title"] = "Admission Records";
}

<style>
    .admin-admissions-header {
        background: linear-gradient(to right, #004d40, #00695c);
        color: white;
        padding: 40px 20px;
        text-align: center;
        border-radius: 0 0 30px 30px;
    }

        .admin-admissions-header h1 {
            font-size: 36px;
            margin-bottom: 10px;
        }

        .admin-admissions-header p {
            font-size: 16px;
            color: #c8e6c9;
        }

    .admissions-table-container {
        margin: 40px auto;
        max-width: 1000px;
        animation: slideIn 0.5s ease-in-out;
    }

    .table thead {
        background-color: #00695c;
        color: white;
    }

    .table tbody tr:hover {
        background-color: #f1f1f1;
        transition: background 0.2s;
    }

    @@keyframes slideIn {
        from

    {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }
</style>

<div class="admin-admissions-header">
    <h1>Admission Records</h1>
    <p>Manage all student admission data submitted via the admission form.</p>
</div>

<div class="container admissions-table-container">
    <table class="table table-bordered table-hover rounded shadow-sm">
        <thead>
            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Course</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Date Applied</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <!-- Example static row (Replace with loop from model/database later) -->
